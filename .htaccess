# --- Pretty URLs: /pricing -> /pricing.php ----------------------------------
RewriteEngine On

# Make sure /account/ and /admin/ resolve to their index.php — some shared
# hosts don't have index.php in the global DirectoryIndex, which causes a
# bare directory request to 403 instead of running the PHP file.
DirectoryIndex index.php index.html

# Force HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Strip trailing slash (except for root)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [L,R=301]

# /foo  -> /foo.php  (only if the .php file exists)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.php -f
RewriteRule ^([^/.]+)$ /$1.php [L]

# /admin/foo -> /admin/foo.php (and similar for any nested folder)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1/$2.php -f
RewriteRule ^([^/.]+)/([^/.]+)$ /$1/$2.php [L]

# /sitemap.xml -> /sitemap.php (auto-generated XML)
RewriteRule ^sitemap\.xml$ /sitemap.php [L]

# /favicon.ico -> the site logo. Browsers request this URL automatically
# even when <link rel="icon"> points elsewhere, so without this rule every
# page load logs a 404.
RewriteRule ^favicon\.ico$ /assets/images/logo-300.webp [L]

# --- Security ----------------------------------------------------------------
# Block dotfiles (e.g. .git, .env)
RedirectMatch 404 /\..*$

# Disable directory listings
Options -Indexes

# Don't expose PHP version + send the modern security headers.
<IfModule mod_headers.c>
  Header unset X-Powered-By
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # Two-year HSTS with preload directive — submit the apex once at https://hstspreload.org
  # if you want to be on the browser preload list. includeSubDomains is intentional.
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  # Lock down powerful browser APIs — none of them are used.
  Header always set Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=(), usb=()"
  # Content-Security-Policy: 'unsafe-inline' is kept for STYLE only because the
  # legacy templates use style="..." attributes in many places. Inline scripts
  # have all been moved to assets/js/portal.js + assets/js/main.js so the
  # script-src can be strict. The plausible.io / Google analytics origins are
  # whitelisted so admins can switch the provider on from /admin/settings.php
  # without anyone having to edit .htaccess.
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://plausible.io https://www.googletagmanager.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://api.qrserver.com https://www.google-analytics.com https://*.tile.openstreetmap.org https://server.arcgisonline.com https://unpkg.com; connect-src 'self' https://plausible.io https://www.google-analytics.com https://*.analytics.google.com https://unpkg.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"
</IfModule>

# Block access to includes/, auth/, and data/ from the web
RewriteRule ^includes/ - [F,L]
RewriteRule ^auth/     - [F,L]
RewriteRule ^data/     - [F,L]

# --- Caching -----------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp        "access plus 1 year"
  ExpiresByType image/png         "access plus 1 year"
  ExpiresByType image/jpeg        "access plus 1 year"
  ExpiresByType image/svg+xml     "access plus 1 year"
  ExpiresByType text/css          "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/x-icon      "access plus 1 year"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# --- Custom error pages ------------------------------------------------------
ErrorDocument 404 /404.php
